---
import DeliveryButton from "@components/buttons/DeliveryButton.astro";
import { Image } from "astro:assets";
import Logo from "@assets/img/logo.svg";
import StarIcon from "@assets/icons/star-filled.svg";
import HeartIcon from "@assets/icons/heart-filled.svg";
import SnowFlakeIcon from "@assets/icons/snowflake.svg";
import UserIcon from "@assets/icons/user-filled.astro";
import BagIcon from "@assets/icons/shopping-bag.astro";

const MENU = [
  {
    name: "Servicios",
    url: "/#servicios",
    icon: StarIcon,
  },
  {
    name: "Somos lo que comemos",
    url: "/#somos",
    icon: HeartIcon,
  },
  {
    name: "Congelados",
    url: "/congelados",
    icon: SnowFlakeIcon,
  },
];
---

<nav
  class="sticky flex flex-row justify-between items-center py-10 px-5 md:px-20 xl:px-48"
>
  <div>
    <a href="/" aria-label="Ir a la página de inicio">
      <Image
        class="transition-all hover:scale-105 duration-500"
        src={Logo}
        alt="Logotipo de Cheffify, representando una marca de venta de comida congelada a domicilio."
      />
    </a>
  </div>
  <ul class="flex-row justify-between items-center gap-10 hidden lg:flex">
    {
      MENU.map(({ name, url, icon }) => (
        <li class="itemLink">
          <a
            class="flex flex-row items-center gap-2 text-sm text-[#262C57]"
            href={url}
          >
            <Image src={icon} alt="Icono" width={14} />
            {name}
          </a>
        </li>
      ))
    }
  </ul>
  <div class="flex flex-row gap-2">
    <DeliveryButton url="/shop" text="Pedir comida" />
    <div class="flex flex-row items-center justify-center gap-px">
      <a
        class="flex flex-row items-center gap-2 bg-[#262C57] text-white text-xs py-2 px-3 rounded-l-full transition-all hover:bg-[#275C73] duration-300"
        href="/login"
      >
        <UserIcon className="size-4" />
        <span class="hidden md:block">Mi Cuenta</span>
      </a>
      <button
        class="bg-[#262C57] py-2 px-3 rounded-r-full transition-all hover:bg-[#275C73] duration-300"
        aria-label="Boton para abrir elCarrito de compras"
      >
        <BagIcon className="size-4" />
      </button>
    </div>
  </div>
</nav>
