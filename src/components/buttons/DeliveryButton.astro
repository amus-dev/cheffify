---
interface Props {
  url?: string;
  text?: string;
}

const { url, text } = Astro.props;

import BellIcon from "@assets/icons/bell-filled.astro";
---

<a
  href={url}
  class="flex flex-row items-center justify-center gap-2 py-2 bg-[#D77466] px-6 text-white text-xs rounded-full transition-all hover:bg-[#275C73] duration-300"
  aria-label="Ir a la sección de pedidos"
>
  <BellIcon className="size-4" />
  <span class="hidden md:block">{text}</span>
</a>
